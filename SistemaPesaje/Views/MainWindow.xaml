<Window x:Class="SistemaPesaje.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SistemaPesaje.ViewModels"
        xmlns:views="clr-namespace:SistemaPesaje.Views"
        Title="Sistema de Pesaje" Height="450" Width="800">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:Dashboard/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditoriaViewModel}">
            <views:Auditoria/>
        </DataTemplate>
    </Window.Resources>

    <ContentControl Content="{Binding VistaActual}"/>

</Window>
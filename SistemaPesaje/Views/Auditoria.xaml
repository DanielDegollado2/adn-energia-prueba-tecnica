<UserControl x:Class="SistemaPesaje.Views.Auditoria"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SistemaPesaje.Views"
        xmlns:vm="clr-namespace:SistemaPesaje.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:AuditoriaViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Placa -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Placa:" FontWeight="Bold" Margin="0,0,10,8"/>
        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PlacaTracto}" Margin="0,0,0,8"/>

        <!-- Conductor -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Conductor:" FontWeight="Bold" Margin="0,0,10,8"/>
        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NombreConductor}" Margin="0,0,0,8"/>

        <!-- Peso Teórico ERP -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Peso Teórico ERP:" FontWeight="Bold" Margin="0,0,10,8"/>
        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PesoTeoricoERP}" Margin="0,0,0,8"/>

        <!-- Peso Bascula Salida -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Peso Bascula Salida:" FontWeight="Bold" Margin="0,0,10,8"/>
        <TextBox  Grid.Row="3" Grid.Column="1" Text="{Binding PesoBasculaSalidaTexto, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap"/>

        <!-- Peso Neto Real -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Peso Neto Real:" FontWeight="Bold" Margin="0,0,10,8"/>
        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PesoNetoReal}" Margin="0,0,0,8"/>

        <!-- Justificación Diferencia -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Justificacion diferencia de peso:" FontWeight="Bold" Margin="0,0,10,8" 
                   TextWrapping="Wrap" Visibility="{Binding RequiereJustificacion, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding JustificacionDiferencia, UpdateSourceTrigger=PropertyChanged}"
         AcceptsReturn="True"
         TextWrapping="Wrap"
         Height="80"
         Margin="0,0,0,8"
         Visibility="{Binding RequiereJustificacion, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Botón Regresar -->
        <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="1"
            Content="Regresar" 
            Command="{Binding RegresarCommand}"
            Margin="10,10,10,10"
            HorizontalAlignment="Left"/>

        <Button Grid.Row="6" Grid.Column="1"
            Content="Autorizar Salida" 
            Command="{Binding ActualizarSalidaCommand}"
            Margin="10,10,10,10"
            HorizontalAlignment="Left"/>
    </Grid>
</UserControl>
